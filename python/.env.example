PORT=8000

# Supabase (mismo que backend Node, vía red interna EasyPanel)
SUPABASE_URL=http://naves_supabase-kong:8000
SUPABASE_SERVICE_ROLE_KEY=

# Token compartido para autenticación de llamadas backend Node → Python
INTERNAL_API_TOKEN=change-me-shared-token

# CORS — por defecto solo se permite el backend Node
CORS_ORIGINS=http://naves_backend:3000
