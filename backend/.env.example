PORT=3000
NODE_ENV=production

# Supabase (compartido en proyecto n8n del mismo EasyPanel)
SUPABASE_URL=https://naves-supabase.huem98.easypanel.host
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Acceso interno (dentro del cluster EasyPanel) — opcional, más rápido
SUPABASE_INTERNAL_URL=http://n8n_supabase-kong:8000

# Encriptación PII (32 bytes en hex o base64)
PII_ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=https://naves-frontend.huem98.easypanel.host,http://localhost:5173

# SMTP (recuperación de clave + notificaciones)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=NAVES INALDE <noreply@inalde.edu.co>

# Frontend URL (para emails de recovery)
FRONTEND_URL=https://naves-frontend.huem98.easypanel.host
